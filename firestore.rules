rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSuperAdmin() {
      return request.auth != null && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superAdmin') ||
        request.auth.token.email == 'cjvkumarraja@gmail.com'
      );
    }

    function isRestaurantOwner(restaurantId) {
      return request.auth != null && (
        // Case 1: restaurant document ID equals the owner's UID (standard registration)
        request.auth.uid == restaurantId ||
        // Case 2: restaurant has an ownerId field pointing to the current user
        (exists(/databases/$(database)/documents/restaurants/$(restaurantId)) &&
         get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.ownerId == request.auth.uid) ||
        // Case 3: check via users/{uid}.restaurantId for edge-case account setups
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'owner' &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.restaurantId == restaurantId)
      );
    }

    // ─── Staff helpers ────────────────────────────────────────────────────────
    function isChef(restaurantId) {
      return request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'chef' &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.restaurantId == restaurantId;
    }

    function isWaiter(restaurantId) {
      return request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'waiter' &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.restaurantId == restaurantId;
    }

    function isRider() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'rider';
    }
    // ─────────────────────────────────────────────────────────────────────────

    match /users/{userId} {
      allow read: if request.auth != null && (
        request.auth.uid == userId ||
        isSuperAdmin() ||
        (exists(/databases/$(database)/documents/users/$(userId)) &&
         isRestaurantOwner(get(/databases/$(database)/documents/users/$(userId)).data.restaurantId))
      );
      allow create: if request.auth != null && (
        isSuperAdmin() ||
        (request.auth.uid == userId && (
          request.resource.data.role == 'owner' ||
          (request.resource.data.role == 'superAdmin' && request.auth.token.email == 'cjvkumarraja@gmail.com')
        )) ||
        // Owner or SuperAdmin can create staff (chef/waiter) documents
        ((isRestaurantOwner(request.resource.data.restaurantId) || isSuperAdmin()) &&
          (request.resource.data.role == 'chef' || request.resource.data.role == 'waiter'))
      );
      allow update: if request.auth != null && (
        isSuperAdmin() ||
        (request.auth.uid == userId && (
          (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])) ||
          (request.resource.data.role == resource.data.role)
        )) ||
        // Owner or SuperAdmin can update staff (chef/waiter) documents
        ((isRestaurantOwner(resource.data.restaurantId) || isSuperAdmin()) &&
          (request.resource.data.role == 'chef' || request.resource.data.role == 'waiter'))
      );
      allow delete: if isSuperAdmin();
    }

    match /sessions/{sessionId} {
      // Checkout links are bearer URLs, so allow direct reads and client-side creation.
      allow get: if true;
      allow list: if false;
      allow create: if (
        request.auth != null && (
          (request.resource.data.restaurantId is string && isRestaurantOwner(request.resource.data.restaurantId)) ||
          isSuperAdmin()
        )
      ) || (
        request.resource.data.status == 'pending_payment' &&
        request.resource.data.orderId is string &&
        request.resource.data.restaurantId is string &&
        exists(/databases/$(database)/documents/restaurants/$(request.resource.data.restaurantId)/orders/$(request.resource.data.orderId)) &&
        request.resource.data.totalAmount == get(/databases/$(database)/documents/restaurants/$(request.resource.data.restaurantId)/orders/$(request.resource.data.orderId)).data.totalAmount &&
        request.resource.data.items == get(/databases/$(database)/documents/restaurants/$(request.resource.data.restaurantId)/orders/$(request.resource.data.orderId)).data.items
      );
      allow update: if request.auth != null && (
        isRestaurantOwner(resource.data.restaurantId) ||
        isSuperAdmin() ||
        (
          resource.data.customerId == request.auth.uid &&
          resource.data.status == 'pending_payment' &&
          request.resource.data.status == 'pending_payment' &&
          (
            (
              request.resource.data.diff(resource.data).affectedKeys().hasOnly(['userConfirmedPayment']) &&
              request.resource.data.userConfirmedPayment == true
            ) ||
            (
              request.resource.data.diff(resource.data).affectedKeys().hasOnly(['items', 'totalAmount']) &&
              request.resource.data.totalAmount >= resource.data.totalAmount
            )
          )
        )
      );
      allow delete: if request.auth != null && (isRestaurantOwner(resource.data.restaurantId) || isSuperAdmin());
    }
    
    match /restaurants/{restaurantId} {
      allow get: if true;
      allow list: if (request.query.limit != null && request.query.limit <= 1) || isSuperAdmin() || isRider();
      allow write: if request.auth != null && (isRestaurantOwner(restaurantId) || isSuperAdmin());
      
      // Admin only collections
      match /items/{itemId} { allow read: if true; allow write: if request.auth != null && (isRestaurantOwner(restaurantId) || isSuperAdmin()); }
      match /categories/{categoryId} { allow read: if true; allow write: if request.auth != null && (isRestaurantOwner(restaurantId) || isSuperAdmin()); }
      match /coupons/{couponId} { allow read: if true; allow write: if request.auth != null && (isRestaurantOwner(restaurantId) || isSuperAdmin()); }
      match /tables/{tableId} {
        allow read: if true;
        allow write: if request.auth != null && (isRestaurantOwner(restaurantId) || isSuperAdmin());
      }

      // ─── Private subcollection — owner-only ──────────────────────────────
      // Stores staffConfig (chefUid, chefPinHash, waiterUid, waiterPinHash)
      // and loginAttempts (rate limit counters).
      // Cloud Functions (Admin SDK) bypass these rules for write access during staff provisioning.
      match /private/{doc} {
        allow read, write: if request.auth != null && (isRestaurantOwner(restaurantId) || isSuperAdmin());
      }
      // ─────────────────────────────────────────────────────────────────────
      
      // Public / Customer writable collections (securely restricted to increments of 1 only)
      match /dailyCounters/{dateStr} {
        allow read: if true;
        allow create: if request.resource.data.keys().hasOnly(['count']) &&
                      request.resource.data.count == 1;
        allow update: if request.resource.data.keys().hasOnly(['count']) &&
                      request.resource.data.count == resource.data.count + 1;
        allow delete: if request.auth != null && (isRestaurantOwner(restaurantId) || isSuperAdmin());
      }
      
      match /requests/{requestId} { 
        allow read: if request.auth != null && (
          isRestaurantOwner(restaurantId) || isSuperAdmin() ||
          isChef(restaurantId) || isWaiter(restaurantId)
        );
        allow create: if request.auth != null;
        // Owner/SuperAdmin: full update/delete
        // Waiter: can only mark status = 'completed' (resolve a request)
        allow update: if request.auth != null && (
          isRestaurantOwner(restaurantId) || isSuperAdmin() ||
          (isWaiter(restaurantId) &&
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) &&
           request.resource.data.status == 'completed')
        );
        allow delete: if request.auth != null && (isRestaurantOwner(restaurantId) || isSuperAdmin());
      }

      match /orders/{orderId} {
        // Read: owner, superAdmin, chef, waiter, or the customer who placed it
        allow read: if request.auth != null && (
          isRestaurantOwner(restaurantId) ||
          isSuperAdmin() ||
          isChef(restaurantId) ||
          isWaiter(restaurantId) ||
          resource.data.customerId == request.auth.uid ||
          (isRider() && resource.data.orderType == 'delivery' && (resource.data.status == 'ready' || resource.data.assignedRiderId == request.auth.uid))
        );
        allow get: if true; // Allow guests to track their own orders by ID

        // Orders can be created directly by anyone (including guest checkout).
        // Enforce initial status to prevent customer from bypassing payment or setting statuses maliciously.
        allow create: if isRestaurantOwner(restaurantId) || isSuperAdmin() || (
          request.resource.data.status == 'pending' &&
          request.resource.data.paymentStatus == 'unpaid' &&
          request.resource.data.items is list &&
          request.resource.data.items.size() > 0 &&
          request.resource.data.totalAmount is number &&
          request.resource.data.totalAmount >= 0 &&
          request.resource.data.orderType in ['dinein', 'delivery'] &&
          request.resource.data.orderSource in ['qr', 'domain'] &&
          (
            request.resource.data.orderType != 'dinein' || 
            !('settings' in get(/databases/$(database)/documents/restaurants/$(restaurantId)).data) ||
            !('ordering' in get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.settings) ||
            !('qr' in get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.settings.ordering) ||
            get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.settings.ordering.qr == true
          )
        );

        // Restaurant owner or super admin can update or delete.
        allow update, delete: if request.auth != null && (isRestaurantOwner(restaurantId) || isSuperAdmin());

        // Chef: can update item status and transition order status between accepted, preparing, and ready
        allow update: if isChef(restaurantId) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'items', 'updatedAt']) &&
          (resource.data.status == 'accepted' || resource.data.status == 'preparing' || resource.data.status == 'ready') &&
          (request.resource.data.status == 'preparing' || request.resource.data.status == 'ready') &&
          request.resource.data.items is list &&
          request.resource.data.items.size() == resource.data.items.size();

        // Waiter: can accept, transition status, confirm payment
        allow update: if isWaiter(restaurantId) &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['status', 'paymentStatus', 'updatedAt', 'timeline']) &&
          (
            // Accept order (pending -> accepted)
            (resource.data.status == 'pending' && request.resource.data.status == 'accepted') ||
            // Start cooking (accepted -> preparing)
            (resource.data.status == 'accepted' && request.resource.data.status == 'preparing') ||
            // Transition preparing -> ready
            (resource.data.status == 'preparing' && request.resource.data.status == 'ready') ||
            // Complete or Serve order
            (resource.data.status == 'ready' && (request.resource.data.status == 'served' || request.resource.data.status == 'completed')) ||
            // Handover Delivery order (ready -> out_for_delivery)
            (resource.data.status == 'ready' && request.resource.data.status == 'out_for_delivery') ||
            // Complete Delivery order (out_for_delivery -> delivered)
            (resource.data.status == 'out_for_delivery' && request.resource.data.status == 'delivered') ||
            // Cancel active order
            (resource.data.status in ['pending', 'accepted', 'preparing', 'ready', 'out_for_delivery'] && request.resource.data.status == 'cancelled') ||
            // Confirm payment
            (request.resource.data.paymentStatus == 'paid' && request.resource.data.status == resource.data.status)
          );

        // Rider: can assign self (when status is ready) and mark delivered
        allow update: if isRider() && (
          // Accept & Pickup order
          (
            resource.data.orderType == 'delivery' &&
            resource.data.status == 'ready' &&
            (resource.data.assignedRiderId == null || !resource.data.keys().hasAny(['assignedRiderId'])) &&
            request.resource.data.assignedRiderId == request.auth.uid &&
            request.resource.data.status == 'out_for_delivery' &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'assignedRiderId', 'assignedRiderName', 'riderAssignedAt', 'updatedAt', 'timeline', 'rider'])
          ) ||
          // Mark as delivered
          (
            resource.data.orderType == 'delivery' &&
            resource.data.assignedRiderId == request.auth.uid &&
            resource.data.status == 'out_for_delivery' &&
            request.resource.data.status == 'delivered' &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt', 'timeline', 'paymentStatus', 'paymentMethod', 'paymentReceivedBy', 'rider'])
          )
        );

        // Customer updates: rating, payment verification
        allow update: if request.auth != null &&
          resource.data.customerId == request.auth.uid &&
          (
            (resource.data.ratingSubmitted == false &&
             request.resource.data.diff(resource.data).affectedKeys().hasOnly(['ratingSubmitted']) &&
             request.resource.data.ratingSubmitted == true)
            ||
            (
              resource.data.paymentStatus == 'unpaid' &&
              request.resource.data.diff(resource.data).affectedKeys().hasOnly(['paymentStatus']) &&
              request.resource.data.paymentStatus == 'verifying'
            )
          );
      }
      match /ratings/{ratingId} { 
        allow read: if request.auth != null && (isRestaurantOwner(restaurantId) || isSuperAdmin()); 
        allow create: if request.auth != null &&
          get(/databases/$(database)/documents/restaurants/$(restaurantId)/orders/$(request.resource.data.orderId)).data.customerId == request.auth.uid &&
          get(/databases/$(database)/documents/restaurants/$(restaurantId)/orders/$(request.resource.data.orderId)).data.ratingSubmitted == false &&
          request.resource.data.keys().hasOnly(['orderId', 'customerName', 'tableNumber', 'stars', 'comment', 'rewardClaimed', 'verified', 'createdAt']) &&
          request.resource.data.orderId is string &&
          request.resource.data.customerName is string &&
          request.resource.data.customerName.size() <= 80 &&
          request.resource.data.tableNumber is string &&
          request.resource.data.tableNumber.size() <= 32 &&
          request.resource.data.stars is int &&
          request.resource.data.stars >= 1 &&
          request.resource.data.stars <= 5 &&
          request.resource.data.comment is string &&
          request.resource.data.comment.size() <= 1000 &&
          request.resource.data.rewardClaimed in ['discount', 'dessert', null] &&
          request.resource.data.verified == false;
        allow update, delete: if request.auth != null && (isRestaurantOwner(restaurantId) || isSuperAdmin()); 
      }

      match /analytics/{dateStr} {
        allow read, write: if request.auth != null && (isRestaurantOwner(restaurantId) || isSuperAdmin());
      }

      match /analyticsMonthly/{monthStr} {
        allow read, write: if request.auth != null && (isRestaurantOwner(restaurantId) || isSuperAdmin());
      }

      match /customers/{customerId} {
        allow read, write: if request.auth != null && (isRestaurantOwner(restaurantId) || isSuperAdmin());
      }
    }

    match /{path=**}/orders/{orderId} {
      allow read: if request.auth != null && (
        isSuperAdmin() ||
        resource.data.customerId == request.auth.uid ||
        (isRider() && resource.data.orderType == 'delivery' && (resource.data.status == 'ready' || resource.data.assignedRiderId == request.auth.uid))
      );
    }

    match /customers/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
      
      match /addresses/{addressId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    match /deliveryBoys/{riderId} {
      allow read: if true;
      allow write: if request.auth != null && (
        request.auth.uid == riderId || 
        isSuperAdmin() || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'owner'
      );
    }

    match /settlements/{settlementId} {
      allow read: if request.auth != null && (
        isSuperAdmin() ||
        resource.data.riderId == request.auth.uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'owner'
      );
      allow create: if request.auth != null && (
        isSuperAdmin() ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'owner'
      );
      allow update, delete: if isSuperAdmin();
    }
  }
}
