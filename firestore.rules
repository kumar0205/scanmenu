rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Restaurants collection
    match /restaurants/{restaurantId} {
      // Anyone can read restaurant info
      allow read: if true;
      // Only the owner can edit
      allow write: if request.auth != null && request.auth.uid == resource.data.ownerId;
      
      // Menu Items, Categories, and Tables are read-only for clients
      match /items/{itemId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.ownerId;
      }
      
      match /categories/{categoryId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.ownerId;
      }
      
      match /tables/{tableId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.ownerId;
      }
      
      // Orders: Clients can create if authenticated (anonymous auth) and read/update only their own orders
      match /orders/{orderId} {
        allow create: if request.auth != null && request.resource.data.status == 'pending';
        allow read: if request.auth != null && request.auth.uid == resource.data.customerId;
        // The owner can read all orders
        allow read: if request.auth != null && request.auth.uid == get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.ownerId;
        
        // Updates: 
        // 1. If owner, allow full update
        // 2. If customer, allow update only if they aren't trying to spoof status or totalAmount
        allow update: if request.auth != null && (
          request.auth.uid == get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.ownerId 
          || 
          (request.auth.uid == resource.data.customerId 
            && request.resource.data.status == resource.data.status 
            && request.resource.data.totalAmount == resource.data.totalAmount)
        );
      }
    }
  }
}
